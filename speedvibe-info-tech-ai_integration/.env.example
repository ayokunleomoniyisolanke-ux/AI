# Copy to .env and fill in values.

# Required for embeddings + chat
OPENAI_API_KEY=sk-...

# Default site to scrape (Speedvibe Info Tech)
SPEEDVIBE_BASE_URL=https://speedvibeinfotech-hub.com.ng

# Chroma persistence (default: chroma_data_speedvibe inside this integration folder)
# CHROMA_PERSIST_DIR=

# OpenAI models
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Voice (Gemini Live) — required when using /speedvibe/web-call inside the main backend
# (same variable as app/common/config.py: GEMINI_API_KEY)
GEMINI_API_KEY=
